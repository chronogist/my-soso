# ─────────────────────────────────────────────────────────────────────────────
# My-Soso environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# DO NOT commit .env. It is gitignored.
#
# In Railway, set these per-service so each service sees only what it needs:
#   • Edge   → Telegram, Discord, WhatsApp, Redis, Postgres, Sentry, app URLs
#   • Worker → SoSoValue, Anthropic, Privy, Telegram, Discord, WhatsApp, Redis,
#              Postgres, Sentry
#   • API    → Privy, Postgres, Redis, Sentry
#   • Dash   → Privy (NEXT_PUBLIC_*), API_URL, Sentry
# ─────────────────────────────────────────────────────────────────────────────


# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development                          # development | production
LOG_LEVEL=info                                # debug | info | warn | error
PORT=3000                                     # per-service override


# ── App URLs (for cross-service references) ─────────────────────────────────
DASHBOARD_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
EDGE_URL=http://localhost:3002                # public URL when deployed; chat platforms POST here


# ── Postgres (Neon) ─────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# ── Redis (Upstash) ─────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → your database → REST/Connect tab
# Note: Upstash provides both `redis://` and `rediss://` (TLS). Use rediss in prod.
REDIS_URL=rediss://default:password@host:port


# ── Privy (auth + embedded wallet + Wave 3 signing) ─────────────────────────
# Get from: https://dashboard.privy.io → your app → API keys
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Preferred: JWKS URL so the API picks up Privy key rotations without a redeploy.
# Get from: Privy Dashboard → Configuration → App settings → JWKS URL.
PRIVY_JWKS_URL=
# Fallback: paste the SPKI/PEM as a single line with \n escapes when your host
# does not support multiline env vars. Set this only when JWKS is not available.
PRIVY_JWT_VERIFICATION_KEY=
# Public version exposed to the Next.js client. Same value as PRIVY_APP_ID.
NEXT_PUBLIC_PRIVY_APP_ID=


# ── SoSoValue API ───────────────────────────────────────────────────────────
# Get from: https://m.sosovalue.com/developer/dashboard (after approval)
SOSOVALUE_API_KEY=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1


# ── Anthropic Claude (LLM) ──────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=
# claude-haiku-4-5-20251001 is the worker default (cheap, fast, good for tool-call orchestration).
# Bump to claude-sonnet-4-6 or claude-opus-4-7 if quality regressions appear in production.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ── Telegram bot ────────────────────────────────────────────────────────────
# Get from: @BotFather on Telegram → /newbot → token
TELEGRAM_BOT_TOKEN=
# Generate yourself (random 32+ char string). Telegram echoes this back as a
# header on every webhook so we can verify the request is really from Telegram.
TELEGRAM_WEBHOOK_SECRET=
# Public URL of the Edge service's Telegram webhook handler.
# In dev, use ngrok or Railway preview URL.
TELEGRAM_WEBHOOK_URL=${EDGE_URL}/webhooks/telegram


# ── Discord app ─────────────────────────────────────────────────────────────
# Get from: https://discord.com/developers/applications → your app
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=                           # used to verify X-Signature-Ed25519 headers
DISCORD_BOT_TOKEN=                            # for outbound API calls (follow-up messages)


# ── WhatsApp Business Cloud API ─────────────────────────────────────────────
# Get from: https://developers.facebook.com → your app → WhatsApp → API setup
WHATSAPP_ACCESS_TOKEN=                        # long-lived system user token
WHATSAPP_PHONE_NUMBER_ID=                     # the ID, not the phone number itself
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Generate yourself. Meta echoes this in webhook verification + as part of signing.
WHATSAPP_VERIFY_TOKEN=
# App secret used to verify X-Hub-Signature-256 on inbound webhooks.
WHATSAPP_APP_SECRET=


# ── Sentry (errors + perf) ──────────────────────────────────────────────────
# Get from: https://sentry.io → your project → settings → client keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development                # development | staging | production


# ── Internal service-to-service auth (optional, recommended) ───────────────
# Random 32+ char string. Used as a shared secret between Edge↔Worker if we ever
# add direct HTTP calls between services (today they only talk via the queue).
INTERNAL_API_SECRET=
LINK_CODE_TTL_SECONDS=600


# ── Feature flags / operational toggles ────────────────────────────────────
# Set to `true` during demos to bypass certain rate limits / use stub data.
DEMO_MODE=false
# Cap Anthropic calls per user per day. Soft warning at 50000, hard cap at 200000.
LLM_DAILY_TOKEN_SOFT_CAP=50000
LLM_DAILY_TOKEN_HARD_CAP=200000
# SoSoValue per-minute outbound bucket (kept under their 10/min ceiling).
SOSOVALUE_RPM_BUDGET=6
# SoSoValue monthly budget tracker (matches their 10k/month plan; raise if upgraded).
SOSOVALUE_MONTHLY_BUDGET=10000

# Prefetcher: cache-warming repeatable job in the worker.
PREFETCH_ENABLED=true
PREFETCH_SYMBOLS=BTC,ETH,SOL
PREFETCH_INTERVAL_MS=60000

# Alert engine: evaluates active alerts every tick. Singleton across the cluster.
ALERT_ENGINE_ENABLED=true
ALERT_ENGINE_INTERVAL_MS=60000
# Per-alert cooldown so a sustained price cross does not spam the user.
ALERT_COOLDOWN_MS=3600000
# News alerts only consider articles within this lookback window.
ALERT_NEWS_LOOKBACK_MS=21600000

# Digest job: hourly tick. Daily fires at this UTC hour, weekly on this UTC dow.
DIGEST_ENABLED=true
DIGEST_INTERVAL_MS=3600000
DIGEST_DAILY_HOUR_UTC=9
DIGEST_WEEKLY_DOW_UTC=1
