{
  "name": "my-soso",
  "version": "0.1.0",
  "private": true,
  "description": "A personal finance agent that lives in your chat app — Telegram, Discord, WhatsApp.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
